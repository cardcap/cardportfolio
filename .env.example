# ── Auth.js ──────────────────────────────────────────────
# Generieren: openssl rand -base64 32
AUTH_SECRET="dein-geheimer-schluessel"

# Öffentliche App-URL (Production)
# AUTH_URL="https://cardcap.de"

# ── Datenbank ────────────────────────────────────────────
# Lokal mit Docker (empfohlen):
#   docker compose -f docker-compose.db.yml up -d
#   npm run db:migrate
DATABASE_URL="postgresql://cardcap:cardcap@localhost:5432/cardcap"

# Production (Neon / Supabase / Railway / eigener Postgres):
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/cardcap?sslmode=require"

# Nur Notfall-Dev ohne Docker (nicht für Production):
# DATABASE_URL="file:./dev.db"

# ── Zugangsschutz (optional, ganze Seite) ────────────────
# SITE_GATE_USER="admin"
# SITE_GATE_PASSWORD="ein-sicheres-passwort"
