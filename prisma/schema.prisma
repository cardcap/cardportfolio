generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon/Vercel: pooled URL in DATABASE_URL, direct for migrate
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  password         String?
  image            String?
  accounts         Account[]
  sessions         Session[]
  wishlistItems    WishlistItem[]
  collectionItems  CollectionItem[]
  sealedItems      SealedItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WishlistItem {
  id             String   @id @default(cuid())
  userId         String
  cardId         String
  name           String
  setName        String
  imageUrl       String
  imageFallbacks String?
  price          Float?
  rarity         String?
  number         String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model CollectionItem {
  id             String   @id @default(cuid())
  userId         String
  tcgCardId      String
  name           String
  setId          String
  setName        String
  number         String
  imageUrl       String
  imageFallbacks String?
  rarity         String?
  language       String   @default("de")
  condition      String   @default("Near Mint")
  quantity       Int      @default(1)
  purchasePrice  Float?
  purchaseDate   String?
  /// JSON: [{ condition, purchasePrice, purchaseDate }] pro Exemplar
  exemplars      Json?
  /// Herkunft z. B. „Geöffnet aus Display …“
  origin         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, tcgCardId])
  @@unique([userId, tcgCardId, condition])
}

/// Sealed-Inventar pro User (Displays, ETBs, …)
model SealedItem {
  id            String   @id @default(cuid())
  userId        String
  /// Stabiler Produkt-Key (Katalog-ID oder Demo-ID)
  productKey    String
  name          String
  setId         String?
  setName       String
  category      String
  language      String   @default("DE")
  condition     String   @default("OVP")
  quantity      Int      @default(1)
  purchasePrice Float
  marketValue   Float?
  imageUrl      String?
  imageFallbacks String?
  ean           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, productKey])
}