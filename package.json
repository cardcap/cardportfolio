{
  "name": "cardcap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3001",
    "build": "prisma generate && node scripts/db-prepare.mjs && next build",
    "postinstall": "prisma generate",
    "start": "next start -H 0.0.0.0 -p 3001",
    "tunnel": "npx --yes localtunnel --port 3001",
    "lint": "eslint",
    "download-cards": "node scripts/download-cards.mjs",
    "patch-sets": "node scripts/patch-sets.mjs",
    "patch-types": "node scripts/patch-card-types.mjs",
    "sync-set-codes": "node scripts/sync-set-codes.mjs",
    "sync-sealed-images": "node scripts/sync-sealed-images.mjs",
    "update-prices": "node scripts/update-prices.mjs",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "node scripts/db-status.mjs",
    "db:studio": "prisma studio",
    "db:admin": "node scripts/ensure-admin.mjs",
    "deploy:vps": "bash scripts/vps-deploy.sh"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
